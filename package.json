{
  "name": "mcp-swarmpit",
  "version": "0.1.0",
  "description": "MCP server for managing Swarmpit Docker Swarm instances",
  "type": "module",
  "bin": {
    "mcp-swarmpit": "./dist/index.js"
  },
  "scripts": {
